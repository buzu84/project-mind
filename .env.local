# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Development flags
# USE_MOCK_AUTH=true   — return a fake dev user instead of requiring Supabase Auth (default: true in dev)
# USE_MOCK_DB=true     — use in-memory DB instead of real Supabase (default: false)
USE_MOCK_AUTH=true
USE_MOCK_DB=true

